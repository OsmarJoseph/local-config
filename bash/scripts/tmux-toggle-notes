#!/usr/bin/env bash

focused_app=$(osascript -e 'tell application "System Events" to get name of first application process whose frontmost is true')

if [ "$focused_app" = "ghostty" ]; then
  current=$(/opt/homebrew/bin/tmux display-message -p '#S')
  if [ "$current" = "notes" ]; then
    /opt/homebrew/bin/tmux switch-client -l
  else
    /opt/homebrew/bin/tmux switch-client -t notes 2>/dev/null 
  fi
else
  /opt/homebrew/bin/tmux switch-client -t notes 2>/dev/null 
  open -a Ghostty
fi
